{
  "rules": {
    "users": {
      // Los admins pueden leer todos los usuarios
      ".read": "auth != null && root.child('users').child(auth.uid).exists() && root.child('users').child(auth.uid).child('rol').val() === 'admin'",
      "$uid": {
        // Todos los usuarios autenticados pueden leer su propio perfil
        // Los admins pueden leer todos los perfiles
        ".read": "auth != null && ($uid === auth.uid || (root.child('users').child(auth.uid).exists() && root.child('users').child(auth.uid).child('rol').val() === 'admin'))",
        
        // Solo admins pueden crear/actualizar usuarios
        // Los usuarios pueden crear/actualizar solo su propio perfil (limitado)
        // Permitir creación del primer usuario (setup inicial)
        ".write": "auth != null && (
          // Admin puede crear/editar cualquier usuario
          (root.child('users').child(auth.uid).exists() && root.child('users').child(auth.uid).child('rol').val() === 'admin') ||
          // Usuario puede crear su propio perfil (primera vez)
          ($uid === auth.uid && !data.exists()) ||
          // Usuario puede editar su propio perfil (sin cambiar rol/departamento)
          ($uid === auth.uid && data.exists() && !newData.hasChild('rol') && !newData.hasChild('departamento')) ||
          // Permitir creación del primer usuario durante setup (cuando no hay usuarios en la BD)
          (!data.exists() && !root.child('users').hasChildren())
        )",
        
        // Validaciones (más flexibles para creación inicial)
        // Permitir actualizaciones parciales (solo si el usuario ya existe)
        ".validate": "!newData.exists() || data.exists() || newData.hasChildren(['nombre', 'apellido', 'email', 'rol', 'departamento', 'activo', 'fechaCreacion'])",
        "nombre": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "apellido": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().matches(/^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$/)"
        },
        "rol": {
          ".validate": "newData.isString() && (newData.val() === 'admin' || newData.val() === 'encargado' || newData.val() === 'empleado')"
        },
        "departamento": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "activo": {
          ".validate": "newData.isBoolean()"
        },
        "fechaCreacion": {
          ".validate": "newData.isString()"
        },
        "codigoPersonal": {
          ".validate": "newData.isString() && newData.val().length >= 4 && newData.val().length <= 20 && newData.val().matches(/^[A-Z0-9]+$/)"
        }
      }
    },
    
    "documents": {
      // Permitir a usuarios autenticados listar documentos (el filtrado se hace en el código)
      ".read": "auth != null",
      
      "$docId": {
        // Todos los usuarios autenticados pueden leer documentos activos
        // Los usuarios pueden leer documentos si están en firmas requeridas o si los crearon
        ".read": "auth != null && (
          data.child('estado').val() === 'activo' &&
          (
            (root.child('users').child(auth.uid).exists() && root.child('users').child(auth.uid).child('rol').val() === 'admin') ||
            data.child('firmasRequeridas').hasChild(auth.uid) ||
            data.child('creadoPor').val() === auth.uid
          )
        )",
        
        // Solo admins y encargados pueden crear documentos
        // Solo el creador o admin puede actualizar
        ".write": "auth != null && (
          (root.child('users').child(auth.uid).exists() && root.child('users').child(auth.uid).child('rol').val() === 'admin') ||
          (
            root.child('users').child(auth.uid).exists() && root.child('users').child(auth.uid).child('rol').val() === 'encargado' &&
            (
              !data.exists() ||
              data.child('creadoPor').val() === auth.uid ||
              (root.child('users').child(auth.uid).exists() && root.child('users').child(auth.uid).child('rol').val() === 'admin')
            )
          )
        )",
        
        // Validaciones
        ".validate": "newData.hasChildren(['codigo', 'departamento', 'categoria', 'subcategoria', 'titulo', 'contenido', 'creadoPor', 'fechaCreacion', 'estado', 'verificacionCode'])",
        "codigo": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "titulo": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200"
        },
        "contenido": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "estado": {
          ".validate": "newData.isString() && (newData.val() === 'activo' || newData.val() === 'eliminado')"
        },
        "firmas": {
          "$firmaId": {
            // Cualquier usuario autenticado puede agregar su propia firma
            ".write": "auth != null && (
              (root.child('users').child(auth.uid).exists() && root.child('users').child(auth.uid).child('rol').val() === 'admin') ||
              (newData.child('userId').val() === auth.uid && !data.exists())
            )",
            ".validate": "newData.hasChildren(['userId', 'nombre', 'rol', 'departamento', 'fecha', 'codigoVerificacion'])"
          }
        },
        "firmasRequeridas": {
          ".validate": "newData.hasChildren() || newData.val() === null"
        }
      }
    },
    
    "requests": {
      // Permitir a usuarios autenticados listar solicitudes (el filtrado se hace en el código)
      ".read": "auth != null",
      
      "$reqId": {
        // Los usuarios pueden leer sus propias solicitudes
        // Los encargados y admins pueden leer solicitudes de su departamento
        // Los admins pueden leer todas
        ".read": "auth != null && (
          (root.child('users').child(auth.uid).exists() && root.child('users').child(auth.uid).child('rol').val() === 'admin') ||
          data.child('solicitante').val() === auth.uid ||
          (
            root.child('users').child(auth.uid).exists() &&
            (root.child('users').child(auth.uid).child('rol').val() === 'encargado' || root.child('users').child(auth.uid).child('rol').val() === 'admin') &&
            data.child('departamento').val() === root.child('users').child(auth.uid).child('departamento').val()
          )
        )",
        
        // Cualquier usuario autenticado puede crear solicitudes
        // Solo encargados y admins pueden actualizar (aprobar/rechazar)
        ".write": "auth != null && (
          !data.exists() ||
          (
            (root.child('users').child(auth.uid).exists() && root.child('users').child(auth.uid).child('rol').val() === 'admin') ||
            (
              root.child('users').child(auth.uid).exists() &&
              (root.child('users').child(auth.uid).child('rol').val() === 'encargado' || root.child('users').child(auth.uid).child('rol').val() === 'admin') &&
              data.child('departamento').val() === root.child('users').child(auth.uid).child('departamento').val() &&
              data.child('estado').val() === 'pendiente'
            )
          )
        )",
        
        // Validaciones
        ".validate": "newData.hasChildren(['tipo', 'tipoNombre', 'solicitante', 'solicitanteNombre', 'departamento', 'estado', 'fechaSolicitud'])",
        "tipo": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "estado": {
          ".validate": "newData.isString() && (newData.val() === 'pendiente' || newData.val() === 'aprobada' || newData.val() === 'rechazada')"
        },
        "solicitante": {
          ".validate": "newData.isString() && newData.val() === auth.uid"
        },
        "datos": {
          ".validate": "newData.hasChildren() || newData.val() === null"
        }
      }
    },
    
    "notifications": {
      // Permitir a usuarios autenticados listar notificaciones (el filtrado se hace en el código)
      ".read": "auth != null",
      
      "$notifId": {
        // Los usuarios solo pueden leer sus propias notificaciones
        ".read": "auth != null && data.child('destinatario').val() === auth.uid",
        
        // Solo el sistema (servidor) o admins pueden crear notificaciones
        // Los usuarios pueden marcar como leída su propia notificación
        ".write": "auth != null && (
          (root.child('users').child(auth.uid).exists() && root.child('users').child(auth.uid).child('rol').val() === 'admin') ||
          (
            data.child('destinatario').val() === auth.uid &&
            newData.child('leida').val() === true &&
            !newData.hasChild('destinatario')
          )
        )",
        
        // Validaciones
        ".validate": "newData.hasChildren(['tipo', 'titulo', 'mensaje', 'destinatario', 'fecha', 'leida'])",
        "destinatario": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "leida": {
          ".validate": "newData.isBoolean()"
        },
        "fecha": {
          ".validate": "newData.isString()"
        }
      }
    },
    
    "counters": {
      // Permitir inicialización del nodo raíz durante setup (cuando no existe)
      // Solo admins/encargados pueden escribir después de la inicialización
      ".write": "auth != null && (
        // Permitir inicialización: nodo no existe (setup inicial)
        !data.exists() ||
        // O si el usuario es admin/encargado
        (root.child('users').child(auth.uid).exists() && 
         (root.child('users').child(auth.uid).child('rol').val() === 'admin' ||
          root.child('users').child(auth.uid).child('rol').val() === 'encargado'))
      )",
      ".read": "auth != null",
      
      "$departamento": {
        "$subcategoria": {
          // Solo admins y encargados pueden leer/actualizar contadores específicos
          ".read": "auth != null && (
            (root.child('users').child(auth.uid).exists() && root.child('users').child(auth.uid).child('rol').val() === 'admin') ||
            (root.child('users').child(auth.uid).exists() && root.child('users').child(auth.uid).child('rol').val() === 'encargado')
          )",
          ".write": "auth != null && (
            (root.child('users').child(auth.uid).exists() && root.child('users').child(auth.uid).child('rol').val() === 'admin') ||
            (root.child('users').child(auth.uid).exists() && root.child('users').child(auth.uid).child('rol').val() === 'encargado')
          )",
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      }
    },
    
    "departamentos": {
      // Todos los usuarios autenticados pueden leer departamentos
      ".read": "auth != null",
      
      "$depId": {
        // Solo admins pueden crear/actualizar/eliminar departamentos
        ".write": "auth != null && (
          root.child('users').child(auth.uid).exists() && 
          root.child('users').child(auth.uid).child('rol').val() === 'admin'
        )",
        
        // Validaciones
        ".validate": "newData.hasChildren(['codigo', 'nombre', 'color', 'icono', 'categorias', 'fechaCreacion', 'activo'])",
        "codigo": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 50"
        },
        "nombre": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200"
        },
        "color": {
          ".validate": "newData.isString() && newData.val().matches(/^#[0-9A-Fa-f]{6}$/)"
        },
        "icono": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "categorias": {
          ".validate": "newData.hasChildren() || newData.val() === null"
        },
        "activo": {
          ".validate": "newData.isBoolean()"
        },
        "fechaCreacion": {
          ".validate": "newData.isString()"
        },
        "fechaActualizacion": {
          ".validate": "newData.isString()"
        }
      }
    }
  }
}
